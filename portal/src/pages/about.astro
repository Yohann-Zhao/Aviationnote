---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "关于";

/**
 * 样式参数说明
 * - `md:grid-cols-[1.4fr_1fr]`: 两列比例布局，左侧文字更宽，右侧信息卡更紧凑。
 * - `text-sm uppercase tracking-[0.12em]`: 标签风格小标题，弱化但有层次。
 * - `underline-offset-4`: 链接下划线与文字拉开距离，视觉更精致。
 * - `dark:bg-slate-900`: 暗色面板底色，保持统一“深灰”而非纯黑。
 */
const ui = {
	title: "text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100",
	lead: "mt-3 text-base leading-7 text-slate-600 dark:text-slate-300",
	layout: "mt-8 grid gap-4 md:grid-cols-[1.4fr_1fr]",
	panel: "rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900",
	text: "mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300"
};
---

<BaseLayout pageTitle={pageTitle} locale="zh">
	<section>
		<h1 class={ui.title}>关于 AviationNote</h1>
		<p class={ui.lead}>
			AviationNote 记录持续飞行训练中的学习笔记、工具索引与实践经验。
		</p>
	</section>

	<section class={ui.layout}>
		<article class={ui.panel}>
			<p class="text-sm font-medium uppercase tracking-[0.12em] text-slate-500 dark:text-slate-400">项目</p>
			<h2 class="mt-2 text-xl font-semibold text-slate-900 dark:text-slate-100">
				一个面向飞行学习的实用笔记站
			</h2>
			<p class={ui.text}>
				AviationNote 旨在为飞行学习者提供一个结构化、易用的知识库，涵盖从基础理论到实战技巧的各个方面。通过持续更新和优化，我们希望帮助更多航空爱好者高效学习、系统复习，并在飞行训练中取得更好的成绩。
				<br /><br />
				本站内容包括但不限于：飞行原理、仪表操作、飞行计划、应急处理、模拟器资源等。我们欢迎所有对飞行感兴趣的人士加入这个社区，共同分享经验与资源。
			</p>
		</article>

		<aside class={ui.panel}>
			<p class="text-sm font-medium uppercase tracking-[0.12em] text-slate-500 dark:text-slate-400">作者</p>
			<h2 class="mt-2 text-lg font-semibold text-slate-900 dark:text-slate-100">Yohann</h2>
			<p class={ui.text}>
				航空爱好者与本站建设者，专注将分散知识整理为稳定可复用的个人学习系统。
			</p>
			<a
				href="https://yohannzhao.netlify.app"
				class="mt-4 inline-flex rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition-colors hover:border-slate-400 hover:text-slate-900 dark:border-slate-700 dark:text-slate-200 dark:decoration-slate-600 dark:hover:border-slate-500 dark:hover:text-slate-100"
			>
				访问个人主页
			</a>
			<a
				href="mailto:yuhan_zhao@nuaa.edu.cn"
				class="mt-4 inline-flex rounded-full border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 underline decoration-slate-300 underline-offset-4 transition-colors hover:border-slate-400 hover:text-slate-900 dark:border-slate-700 dark:text-slate-200 dark:decoration-slate-600 dark:hover:border-slate-500 dark:hover:text-slate-100"
			>
				联系作者
			</a>
		</aside>
	</section>
</BaseLayout>
