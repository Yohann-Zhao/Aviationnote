---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "首页";

/**
 * Tailwind 参数说明（新手友好）
 * - `max-w-3xl` / `max-w-6xl`: 控制内容最大宽度，数字越大越宽。
 * - `px-4 sm:px-6`: 横向内边距，`sm:` 表示 >=640px 屏幕时使用后者。
 * - `py-12`: 纵向内边距，值越大上下留白越多。
 * - `rounded-2xl`: 圆角大小，`xl/2xl/3xl` 逐步变圆。
 * - `shadow-sm`: 轻阴影。可换 `shadow`（更明显）或删掉（更克制）。
 * - `border-slate-200`: 边框颜色。`slate-100` 更淡，`slate-300` 更明显。
 * - `text-slate-600`: 正文色。`500` 更深，`700` 对比更强。
 * - `dark:*`: 暗色主题覆盖值。例如 `dark:bg-slate-900` 只在暗色主题生效。
 */
const ui = {
	heroCard:
		"rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-10 dark:border-slate-800 dark:bg-slate-900",
	heroTitle: "text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100",
	heroText: "mt-4 max-w-3xl text-base leading-7 text-slate-600 dark:text-slate-300",
	grid: "mt-10 grid gap-4 md:grid-cols-3",
	infoCard: "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900",
	infoTitle: "text-base font-semibold text-slate-900 dark:text-slate-100",
	infoText: "mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300"
};
---

<BaseLayout pageTitle={pageTitle} locale="zh">
	<section class={ui.heroCard}>
		<p class="text-sm font-medium uppercase tracking-[0.12em] text-slate-500 dark:text-slate-400">AviationNote</p>
		<h1 class={ui.heroTitle}>一个面向飞行学习的实用笔记和资源站</h1>
		<p class={ui.heroText}>
			AviationNote 是一个非营利性的原创学习资源共享项目，包含飞行理论笔记、实用工具和资源参考等。
			站点强调非营利性、实用性和可持续扩展。站点笔记内容和工具资源由作者原创编写、整理和开发。
		</p>
		<div class="mt-6 flex flex-wrap gap-3">
			<a
				href="/notes/"
				class="inline-flex rounded-full bg-slate-900 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-700 dark:bg-slate-100 dark:text-slate-900 dark:hover:bg-slate-300"
			>
				从笔记开始
			</a>
			<a
				href="/resources/"
				class="inline-flex rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:border-slate-400 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-slate-500 dark:hover:text-slate-100"
			>
				打开资源页
			</a>
		</div>
	</section>

	<section class={ui.grid}>
		<article class={ui.infoCard}>
			<h2 class={ui.infoTitle}>站点用途</h2>
			<p class={ui.infoText}>
				本站作者分享原创学习笔记，帮助初入飞行领域的朋友们快速建立对各个学科的感性认识，也帮助应试的朋友们在备考时尽快抓住考点和考前快速回看等等。
			</p>
			<p class={ui.infoText}>
				本站还分享航空英语资源、原创实用工具等等。无线电通信呼号练习、风三角飞行计划计算器 等工具资源在持续开发和完善中。
			</p>
			<p class={ui.infoText}>
				本站作者初衷为个人复习，提升个人技能。与此同时，将所有内容分享给愿意学习的朋友们。
			</p>
		</article>
		<article class={ui.infoCard}>
			<h2 class={ui.infoTitle}>使用建议</h2>
			<p class={ui.infoText}>
			本站的笔记提供系统化的知识框架，精炼考试重点，使学习更有条理。然而，所有知识的基础仍然是课本和知识点，学员应在充分自学课本和知识点的基础上，结合本站的内容，形成自己的体系。
			</p>
			<p class={ui.infoText}>
				本站内容均为作者个人理解和总结，难免存在不完善之处。请保持批判性思维。本站内容仅供学习参考，不能替代正式教材和专业培训。对于考试内容的理解和应用，请以官方教材和培训机构的指导为准。
				如发现内容错误或有改进建议，欢迎 <a href="mailto:yuhan_zhao@nuaa.edu.cn" class="ml-1 font-medium text-slate-800 underline decoration-slate-300 underline-offset-4 transition-colors hover:decoration-slate-700 dark:text-slate-200 dark:decoration-slate-600 dark:hover:decoration-slate-300">联系作者</a>。
			</p>
		</article>
		<article class={ui.infoCard}>
			<h2 class={ui.infoTitle}>版权说明</h2>
			<p class={ui.infoText}>
				除特别注明外，本站内容均为原创。外部资源遵循各自的授权和署名规则。
				如发现未正确标注的来源或潜在版权问题，请 <a href="mailto:yuhan_zhao@nuaa.edu.cn" class="ml-1 font-medium text-slate-800 underline decoration-slate-300 underline-offset-4 transition-colors hover:decoration-slate-700 dark:text-slate-200 dark:decoration-slate-600 dark:hover:decoration-slate-300">联系作者</a>，将尽快更正。
			</p>
			<p class={ui.infoText}>
				本站保留所有权利，欢迎合理使用和分享站点内容。
				任何未经授权的商业使用和其它侵权行为都将面临承担法律责任。
			</p>
		</article>
	</section>
</BaseLayout>
