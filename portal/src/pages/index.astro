---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Home";

/**
 * Tailwind 参数说明（新手友好）
 * - `max-w-3xl` / `max-w-6xl`: 控制内容最大宽度，数字越大越宽。
 * - `px-4 sm:px-6`: 横向内边距，`sm:` 表示 >=640px 屏幕时使用后者。
 * - `py-12`: 纵向内边距，值越大上下留白越多。
 * - `rounded-2xl`: 圆角大小，`xl/2xl/3xl` 逐步变圆。
 * - `shadow-sm`: 轻阴影。可换 `shadow`（更明显）或删掉（更克制）。
 * - `border-slate-200`: 边框颜色。`slate-100` 更淡，`slate-300` 更明显。
 * - `text-slate-600`: 正文色。`500` 更深，`700` 对比更强。
 * - `dark:*`: 暗色主题覆盖值。例如 `dark:bg-slate-900` 只在暗色主题生效。
 */
const ui = {
	heroCard:
		"rounded-3xl border border-slate-200 bg-white p-6 shadow-sm sm:p-10 dark:border-slate-800 dark:bg-slate-900",
	heroTitle: "text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100",
	heroText: "mt-4 max-w-3xl text-base leading-7 text-slate-600 dark:text-slate-300",
	grid: "mt-10 grid gap-4 md:grid-cols-3",
	infoCard: "rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900",
	infoTitle: "text-base font-semibold text-slate-900 dark:text-slate-100",
	infoText: "mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300"
};
---

<BaseLayout pageTitle={pageTitle}>
	<!-- 首页：Landing Page（站点定位 + 使用方法 + 版权说明） -->
	<section class={ui.heroCard}>
		<p class="text-sm font-medium uppercase tracking-[0.12em] text-slate-500 dark:text-slate-400">AviationNote</p>
		<h1 class={ui.heroTitle}>A focused aviation knowledge hub for study and practice</h1>
		<p class={ui.heroText}>
			AviationNote is a personal learning project that organizes flight-theory notes, practical references,
			and reusable tools into one clean space. The site is designed to be calm, readable, and easy to
			expand.
		</p>
		<div class="mt-6 flex flex-wrap gap-3">
			<a
				href="/notes/"
				class="inline-flex rounded-full bg-slate-900 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-slate-700 dark:bg-slate-100 dark:text-slate-900 dark:hover:bg-slate-300"
			>
				Start with Notes
			</a>
			<a
				href="/resources/"
				class="inline-flex rounded-full border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 transition-colors hover:border-slate-400 hover:text-slate-900 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300 dark:hover:border-slate-500 dark:hover:text-slate-100"
			>
				Open Resources
			</a>
		</div>
	</section>

	<section class={ui.grid}>
		<article class={ui.infoCard}>
			<h2 class={ui.infoTitle}>Why this site</h2>
			<p class={ui.infoText}>
				Build a reliable personal system for aviation learning so notes and tools are easy to revisit before
				training and exams.
			</p>
		</article>
		<article class={ui.infoCard}>
			<h2 class={ui.infoTitle}>How to use</h2>
			<p class={ui.infoText}>
				Use Notes for structured reading, then jump to Resources for calculators, links, and quick-reference
				materials.
			</p>
		</article>
		<article class={ui.infoCard}>
			<h2 class={ui.infoTitle}>Copyright</h2>
			<p class={ui.infoText}>
				Personal notes are original unless stated otherwise. External resources remain under their own
				licenses and attribution terms.
			</p>
		</article>
	</section>
</BaseLayout>
