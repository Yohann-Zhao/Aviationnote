---
import BaseLayout from "../../layouts/BaseLayout.astro";
const pageTitle = "Notes";

const ui = {
	title: "text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100",
	lead: "mt-3 max-w-3xl text-base leading-7 text-slate-600 dark:text-slate-300",
	grid: "mt-8 grid gap-4 md:grid-cols-2",
	card: "flex flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900",
	cardTitle: "text-base font-semibold text-slate-900 dark:text-slate-100",
	cardText: "mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300",
	cardFooter: "mt-auto pt-4",
	link: "inline-flex rounded-xl bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-200 hover:text-slate-900 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700 dark:hover:text-slate-100"
};
---

<BaseLayout pageTitle={pageTitle} locale="en">
	<section>
		<h1 class={ui.title}>Notes</h1>
		<p class={ui.lead}>
			Structured aviation notes for theory review, checklist memory, and recurrent study. This page is ready
			for future expansion by subject and training phase.
		</p>
	</section>

	<section class={ui.grid}>
		<article class={ui.card}>
			<h2 class={ui.cardTitle}>CAAC Commercial/Airline Transport Pilot License Theory Notes</h2>
			<p class={ui.cardText}>
				Group notes into modules such as meteorology, navigation, regulations, and radio communication.
			</p>
			<div class={ui.cardFooter}>
				<a class={ui.link} href="https://aviationnote.com/pilot_license_theory/caac_pilot_theory/">View Subjects</a>
			</div>
		</article>
		<article class={ui.card}>
			<h2 class={ui.cardTitle}>A320 CBT Notes</h2>
			<p class={ui.cardText}>Organize notes by CBT modules, focusing on key concepts.</p>
			<div class={ui.cardFooter}>
				<a class={ui.link} href="https://a320note.netlify.app/">View Modules</a>
			</div>
		</article>
		<article class={ui.card}>
			<h2 class={ui.cardTitle}>CASA Commercial Pilot License Theory Notes</h2>
			<p class={ui.cardText}>
				Group notes into modules such as meteorology, navigation, regulations, and radio communication.
			</p>
			<div class={ui.cardFooter}>
				<a class={ui.link} href="https://aviationnote.com/theory.html">View Subjects</a>
			</div>
		</article>
		<article class={ui.card}>
			<h2 class={ui.cardTitle}>DA40 / DA42 Flight Training & Ground Component Notes</h2>
			<p class={ui.cardText}>
				Reserve space for short reflections after each training session to build personal operating insight.
			</p>
			<div class={ui.cardFooter}>
				<a class={ui.link} href="https://aviationnote.com/flight-training.html">View Notes</a>
			</div>
		</article>
	</section>
</BaseLayout>
