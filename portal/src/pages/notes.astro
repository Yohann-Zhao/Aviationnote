---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "笔记";

/**
 * 样式参数说明（可直接改数字试效果）
 * - `grid gap-4 md:grid-cols-2`: 小屏单列，大屏两列；`gap-4` 是卡片间距。
 * - `text-sm leading-6`: 正文尺寸 + 行高，阅读更稳定。
 * - `border border-slate-200`: 亮色主题边框，强调“专业、克制”。
 * - `dark:border-slate-800`: 暗色主题边框，避免对比过强刺眼。
 * - `dark:text-slate-300`: 暗色正文建议用灰白色，不建议纯白大段正文。
 */
const ui = {
	title: "text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl dark:text-slate-100",
	lead: "mt-3 max-w-3xl text-base leading-7 text-slate-600 dark:text-slate-300",
	grid: "mt-8 grid gap-4 md:grid-cols-2",
	card: "flex flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900",
	cardTitle: "text-base font-semibold text-slate-900 dark:text-slate-100",
	cardText: "mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300",
	cardFooter: "mt-auto pt-4",
	link: "inline-flex rounded-xl bg-slate-100 px-3 py-1.5 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-200 hover:text-slate-900 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700 dark:hover:text-slate-100"
};
---

<BaseLayout pageTitle={pageTitle} locale="zh">
	<section>
		<h1 class={ui.title}>笔记</h1>
		<p class={ui.lead}>
			本站笔记内容由作者原创编写和整理，适合飞行学员使用，也欢迎对飞行理论和训练感兴趣的航空爱好者参考学习。
		</p>
	</section>

	<section class={ui.grid}>
		<article class={ui.card}>
			<h2 class={ui.cardTitle}>国内 商照 / 仪表 / 航线照 理论笔记</h2>
			<p class={ui.cardText}>
			适合飞行学员备考国内飞行执照使用。
			</p>
			<p class={ui.cardText}>
			包括国内商照理论和仪表理论笔记、航线照理论笔记。内容均按科目和模块组织。
			</p>
			<div class={ui.cardFooter}>
				<a class={ui.link} href="https://aviationnote.com/pilot_license_theory/caac_pilot_theory/">查看科目</a>
			</div>
		</article>
		<article class={ui.card}>
			<h2 class={ui.cardTitle}>A320 CBT 笔记</h2>
			<p class={ui.cardText}>
				适合进行 A320 机型训练的学员，或对 A320 系统和操作感兴趣的航空爱好者。
			</p>
			<p class={ui.cardText}>由线上可获取的A320 CBT 英文视频内容整理，笔记按模块组织，条理清晰，有完整的官方文字讲解和图示。</p>
			<div class={ui.cardFooter}>
				<a class={ui.link} href="https://a320note.netlify.app/">查看模块</a>
			</div>
		</article>
		<article class={ui.card}>
			<h2 class={ui.cardTitle}>澳大利亚 商照 理论笔记</h2>
			<p class={ui.cardText}>
				适合飞行学员备考澳大利亚飞行执照使用，也适合对英文航空理论感兴趣的学者和航空爱好者。
			</p>
			<p class={ui.cardText}>
				按飞机系统、空气动力学、气象、航行、性能等模块组织内容，便于分学科学习。
			</p>
			<div class={ui.cardFooter}>
				<a class={ui.link} href="https://aviationnote.com/theory.html">查看科目</a>
			</div>
		</article>
		<article class={ui.card}>
			<h2 class={ui.cardTitle}>澳大利亚 航校飞行训练笔记</h2>
			<p class={ui.cardText}>
				适合进行 DA40 或 DA42 机型训练的学员，国外航校学员，或对飞行训练流程和内容感兴趣的航空爱好者。
			</p>
			<p class={ui.cardText}>
				笔记基于个人飞行训练经验整理，仅供参考，不能替代任何官方材料。
			</p>
			<div class={ui.cardFooter}>
				<a class={ui.link} href="https://aviationnote.com/flight-training.html">查看笔记</a>
			</div>
		</article>
	</section>
</BaseLayout>
