---
import Navigation from "./Navigation.astro";
import {
	localizePath,
	type Locale
} from "../utils/i18n";

const locale: Locale = Astro.props.locale ?? "zh";
const currentPath = Astro.url.pathname;
const zhPath = localizePath(currentPath, "zh");
const enPath = localizePath(currentPath, "en");
const themeButtonText = locale === "zh" ? "主题" : "Theme";
const menuSrText = locale === "zh" ? "切换菜单" : "Toggle menu";
---

<header class="sticky top-0 z-40 border-b border-slate-200/80 bg-white/90 backdrop-blur dark:border-slate-800 dark:bg-slate-950/85">
	<div class="mx-auto flex w-full max-w-6xl items-center px-4 py-3 sm:px-6 lg:px-8">
		<a href={localizePath("/", locale)} class="mr-4 min-w-fit text-sm font-semibold tracking-wide text-slate-900 dark:text-slate-100">
			AviationNote
		</a>

		<!-- 桌面端导航 -->
		<nav class="hidden flex-1 md:block" aria-label="Primary">
			<Navigation locale={locale} />
		</nav>

		<!-- 桌面端操作区 -->
		<div class="ml-auto hidden items-center gap-2 md:flex">
			<!-- 语言切换：通过中英文路由互跳 -->
			<nav
				class="inline-flex items-center rounded-full border border-slate-300 bg-white dark:border-slate-700 dark:bg-slate-900"
				role="group"
				aria-label={locale === "zh" ? "语言切换" : "Language switch"}
			>
				<a
					href={zhPath}
					aria-current={locale === "zh" ? "page" : undefined}
					class:list={[
						"rounded-full px-2.5 py-1.5 text-xs font-medium",
						locale === "zh"
							? "bg-slate-900 text-white dark:bg-slate-100 dark:text-slate-900"
							: "text-slate-600 dark:text-slate-300"
					]}
				>
					中
				</a>
				<a
					href={enPath}
					aria-current={locale === "en" ? "page" : undefined}
					class:list={[
						"rounded-full px-2.5 py-1.5 text-xs font-medium",
						locale === "en"
							? "bg-slate-900 text-white dark:bg-slate-100 dark:text-slate-900"
							: "text-slate-600 dark:text-slate-300"
					]}
				>
					EN
				</a>
			</nav>

			<button
				type="button"
				data-theme-toggle
				data-locale={locale}
				class="inline-flex min-w-24 items-center justify-center rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-700 transition-colors hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
			>
				<span data-theme-label>{themeButtonText}</span>
			</button>
		</div>

		<!-- 移动端菜单按钮 -->
		<button
			type="button"
				data-mobile-menu-toggle
				aria-expanded="false"
				aria-controls="mobile-nav-panel"
				aria-label={locale === "zh" ? "打开菜单" : "Open menu"}
				data-menu-label-open={locale === "zh" ? "打开菜单" : "Open menu"}
				data-menu-label-close={locale === "zh" ? "关闭菜单" : "Close menu"}
				class="ml-auto inline-flex items-center justify-center rounded-full border border-slate-300 bg-white p-2 text-slate-700 transition-colors hover:bg-slate-100 md:hidden dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
			>
			<span class="sr-only">{menuSrText}</span>
			<svg data-icon-open xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg data-icon-close xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12M18 6l-12 12" />
			</svg>
		</button>
	</div>

	<!-- 移动端面板 -->
	<div
		id="mobile-nav-panel"
		data-mobile-menu-panel
		class="hidden border-t border-slate-200 bg-white px-4 pb-4 pt-3 md:hidden dark:border-slate-800 dark:bg-slate-950"
	>
		<nav aria-label="Mobile primary">
			<Navigation mobile={true} locale={locale} />
		</nav>

		<div class="justify-end mt-3 flex items-center gap-2">
			<nav
				class="inline-flex items-center rounded-full border border-slate-300 bg-white dark:border-slate-700 dark:bg-slate-900"
				role="group"
				aria-label={locale === "zh" ? "语言切换" : "Language switch"}
			>
				<a
					href={zhPath}
					aria-current={locale === "zh" ? "page" : undefined}
					class:list={[
						"rounded-full px-2.5 py-1.5 text-xs font-medium",
						locale === "zh"
							? "bg-slate-900 text-white dark:bg-slate-100 dark:text-slate-900"
							: "text-slate-600 dark:text-slate-300"
					]}
				>
					中
				</a>
				<a
					href={enPath}
					aria-current={locale === "en" ? "page" : undefined}
					class:list={[
						"rounded-full px-2.5 py-1.5 text-xs font-medium",
						locale === "en"
							? "bg-slate-900 text-white dark:bg-slate-100 dark:text-slate-900"
							: "text-slate-600 dark:text-slate-300"
					]}
				>
					EN
				</a>
			</nav>

			<button
				type="button"
				data-theme-toggle
				data-locale={locale}
				class="inline-flex min-w-24 items-center justify-center rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-700 transition-colors hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
			>
				<span data-theme-label>{themeButtonText}</span>
			</button>
		</div>
	</div>
</header>

<script is:inline>
	/*
	 * Header 交互说明：
	 * 1) 主题切换：同步更新所有 `data-theme-label` 文案。
	 * 2) 移动菜单：点击按钮展开/收起面板，切换汉堡/关闭图标。
	 */
	(() => {
		const html = document.documentElement;
		const labels = {
			zh: { dark: "深色", light: "浅色", toLight: "切换到浅色主题", toDark: "切换到深色主题" },
			en: { dark: "Dark", light: "Light", toLight: "Switch to light theme", toDark: "Switch to dark theme" }
		};

		const themeButtons = document.querySelectorAll("[data-theme-toggle]");
		const themeLabels = document.querySelectorAll("[data-theme-label]");
		const syncThemeLabel = () => {
			const isDark = html.classList.contains("dark");
			const locale = document.documentElement.lang === "zh" ? "zh" : "en";
			const text = labels[locale];
			themeLabels.forEach((label) => {
				label.textContent = isDark ? text.dark : text.light;
			});
			themeButtons.forEach((btn) => {
				btn.setAttribute("aria-label", isDark ? text.toLight : text.toDark);
			});
		};
		syncThemeLabel();
		themeButtons.forEach((button) => {
			button.addEventListener("click", () => {
				const nextIsDark = !html.classList.contains("dark");
				html.classList.toggle("dark", nextIsDark);
				localStorage.setItem("theme", nextIsDark ? "dark" : "light");
				syncThemeLabel();
			});
		});

		const toggle = document.querySelector("[data-mobile-menu-toggle]");
		const panel = document.querySelector("[data-mobile-menu-panel]");
		const openIcon = document.querySelector("[data-icon-open]");
		const closeIcon = document.querySelector("[data-icon-close]");
		if (!toggle || !panel || !openIcon || !closeIcon) return;

		const setMenuState = (expanded) => {
			toggle.setAttribute("aria-expanded", expanded ? "true" : "false");
			const label = expanded ? toggle.getAttribute("data-menu-label-close") : toggle.getAttribute("data-menu-label-open");
			if (label) toggle.setAttribute("aria-label", label);
			panel.classList.toggle("hidden", !expanded);
			openIcon.classList.toggle("hidden", expanded);
			closeIcon.classList.toggle("hidden", !expanded);
		};
		setMenuState(false);

		toggle.addEventListener("click", () => {
			const expanded = toggle.getAttribute("aria-expanded") === "true";
			setMenuState(!expanded);
		});
	})();
</script>
