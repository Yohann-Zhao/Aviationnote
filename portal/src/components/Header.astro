---
import Navigation from './Navigation.astro';
---

<header class="sticky top-0 z-30 border-b border-slate-200/80 bg-white/90 backdrop-blur dark:border-slate-800 dark:bg-slate-950/85">
	<div class="mx-auto flex w-full max-w-6xl items-center px-4 py-4 sm:px-6 lg:px-8">
		<div class="mr-8 min-w-fit">
			<a href="/" class="text-sm font-semibold tracking-wide text-slate-900 dark:text-slate-100">AviationNote</a>
		</div>
		<nav class="w-full">
			<Navigation />
		</nav>
		<div class="ml-4">
			<!--
				主题按钮参数说明：
				- `rounded-full px-3 py-1.5`: 药丸按钮尺寸
				- `border-slate-300 dark:border-slate-700`: 亮暗边框分别设置
				- `data-theme-toggle`: 被下方 JS 绑定点击事件
			-->
			<button
				type="button"
				data-theme-toggle
				class="inline-flex min-w-24 items-center justify-center rounded-full border border-slate-300 bg-white px-3 py-1.5 text-xs font-medium text-slate-700 transition-colors hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:bg-slate-800"
			>
				<span data-theme-label>Theme</span>
			</button>
		</div>
	</div>
</header>

<script is:inline>
	/*
	 * 主题切换逻辑：
	 * - 点击按钮在 `dark` 类和 `light` 状态间切换
	 * - 同步写入 localStorage，让用户下次访问保持同一主题
	 */
	(() => {
		const html = document.documentElement;
		const button = document.querySelector("[data-theme-toggle]");
		const label = document.querySelector("[data-theme-label]");
		if (!button || !label) return;

		const syncLabel = () => {
			const isDark = html.classList.contains("dark");
			label.textContent = isDark ? "Dark" : "Light";
			button.setAttribute("aria-label", isDark ? "Switch to light theme" : "Switch to dark theme");
		};

		syncLabel();
		button.addEventListener("click", () => {
			const nextIsDark = !html.classList.contains("dark");
			html.classList.toggle("dark", nextIsDark);
			localStorage.setItem("theme", nextIsDark ? "dark" : "light");
			syncLabel();
		});
	})();
</script>
