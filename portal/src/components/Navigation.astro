---
import { localizePath, type Locale } from "../utils/i18n";

const { mobile = false } = Astro.props;
const currentPath = Astro.url.pathname;
const locale: Locale = Astro.props.locale ?? "zh";
const navItems = [
	{ label: locale === "zh" ? "首页" : "Home", href: localizePath("/", locale), exact: true },
	{ label: locale === "zh" ? "笔记" : "Notes", href: localizePath("/notes/", locale), exact: false },
	{ label: locale === "zh" ? "资源" : "Resources", href: localizePath("/resources/", locale), exact: false },
	{ label: locale === "zh" ? "关于" : "About", href: localizePath("/about/", locale), exact: false }
];

/**
 * 参数说明（Navigation）
 * - `mobile = false`: 默认桌面布局，`true` 时输出移动端纵向导航。
 * - 桌面：`gap-2 sm:gap-3`，紧凑横向排列。
 * - 移动：`flex-col gap-2`，触控友好，按钮更高。
 */
const listClass = mobile
	? "flex flex-col gap-2"
	: "flex flex-wrap items-center gap-2 sm:gap-3";

const itemBase = mobile
	? "inline-flex w-full rounded-xl px-3 py-2.5 text-sm font-medium transition-colors"
	: "inline-flex rounded-full px-3 py-1.5 text-sm font-medium transition-colors";
---

<ul class={listClass}>
	{
		navItems.map((item) => {
			const normalizedCurrent = currentPath.endsWith("/") && currentPath.length > 1 ? currentPath.slice(0, -1) : currentPath;
			const normalizedHref = item.href.endsWith("/") && item.href.length > 1 ? item.href.slice(0, -1) : item.href;
			const isActive =
				normalizedCurrent === normalizedHref || (!item.exact && normalizedCurrent.startsWith(`${normalizedHref}/`));
			return (
				<li>
					<a
						href={item.href}
						aria-current={isActive ? "page" : undefined}
						class:list={[
							itemBase,
							isActive
								? "bg-slate-900 text-white dark:bg-slate-100 dark:text-slate-900"
								: "text-slate-700 hover:bg-slate-100 hover:text-slate-900 dark:text-slate-300 dark:hover:bg-slate-800 dark:hover:text-slate-100"
						]}
					>
						{item.label}
					</a>
				</li>
			);
		})
	}
</ul>
